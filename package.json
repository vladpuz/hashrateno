{
  "name": "hashrateno",
  "version": "3.0.0",
  "description": "Hashrate.no API client",
  "keywords": [
    "mining",
    "calculator",
    "hashrateno",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladpuz/hashrateno.git"
  },
  "license": "MIT",
  "author": "Vladislav Puzyrev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm run format",
    "format": "prettier --check .",
    "lint": "eslint .",
    "prepack": "npm run build && npm run check",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-vladpuz": "^4.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "prettier-config-vladpuz": "^3.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  }
}
